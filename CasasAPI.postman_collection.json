{
  "info": {
    "name": "Casas API CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET - Obtener todas las casas",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/casas",
          "host": ["{{base_url}}"],
          "path": ["casas"]
        }
      }
    },
    {
      "name": "GET - Obtener casa por ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/casas/1",
          "host": ["{{base_url}}"],
          "path": ["casas", "1"]
        }
      }
    },
    {
      "name": "POST - Crear nueva casa",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"direccion\": \"Av. Principal 123\",\n  \"distrito\": \"Miraflores\",\n  \"numeroHabitaciones\": 3,\n  \"tipoCasa\": \"Chalet\",\n  \"areaMetrosCuadrados\": 120.5,\n  \"precio\": 250000\n}"
        },
        "url": {
          "raw": "{{base_url}}/casas",
          "host": ["{{base_url}}"],
          "path": ["casas"]
        }
      }
    },
    {
      "name": "PUT - Actualizar casa",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": 1,\n  \"direccion\": \"Nueva dirección 456\",\n  \"distrito\": \"San Isidro\",\n  \"numeroHabitaciones\": 4,\n  \"tipoCasa\": \"Adosada\",\n  \"areaMetrosCuadrados\": 150.0,\n  \"precio\": 320000\n}"
        },
        "url": {
          "raw": "{{base_url}}/casas/1",
          "host": ["{{base_url}}"],
          "path": ["casas", "1"]
        }
      }
    },
    {
      "name": "DELETE - Eliminar casa",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/casas/1",
          "host": ["{{base_url}}"],
          "path": ["casas", "1"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://localhost:7137/api",
      "type": "string"
    }
  ]
}